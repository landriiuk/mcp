{
  "name": "mcp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "emulators": "JAVA_HOME=\"${JAVA_HOME:-$(/usr/libexec/java_home 2>/dev/null || echo /Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home)}\" firebase emulators:start --only firestore --project demo-inklex-local --import=./.firebase-data --export-on-exit=./.firebase-data",
    "dev:local": "npm run emulators",
    "build": "vite build",
    "build:frontend": "vite build",
    "prepare-deploy": "npm run build:frontend && rm -rf backend/public && mkdir -p backend/public && cp -r dist/* backend/public/",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^14.27.0",
    "globals": "^17.6.0",
    "sass-embedded": "^1.100.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
