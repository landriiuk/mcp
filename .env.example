# =============================================================================
# InkLex — local secrets / config (copy to `.env`, never commit `.env`)
# `.env` is gitignored. Only `.env.example` is safe to commit.
# =============================================================================

# --- Firebase Web SDK (required for the app) ---
# Where: Firebase Console → Project settings → Your apps → SDK snippet
#
# NOTE: VITE_* values are embedded in the browser bundle (visible to users).
# They are NOT like a server password. Real protection = Firestore Security Rules
# (+ Auth later). Still keep them in env so nothing is hardcoded in source.
#
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Do NOT put these in VITE_* / frontend ---
# Firebase Admin / service account JSON, private keys, Supabase service_role,
# Postgres passwords — only in private server env if you ever use a backend again.
